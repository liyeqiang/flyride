<view class="container">
  <view class="card" wx:if="{{!loading && orders.length === 0}}">
    <view class="card-desc">暂无预约记录</view>
  </view>

  <view class="card order-card" wx:for="{{orders}}" wx:key="_id" bindtap="goOrder" data-order-id="{{item._id}}">
    <view class="order-row">
      <text class="order-id-small">{{item._id}}</text>
      <text class="status-tag {{item.status === 'completed' ? 'done' : 'pending'}}">{{item.statusText}}</text>
    </view>
    <view class="order-row">
      <text class="price-label">姓名</text>
      <text class="price-value">{{item.riderName}}</text>
    </view>
    <view class="order-row">
      <text class="price-label">创建时间</text>
      <text class="price-value">{{item.createdAtText}}</text>
    </view>
  </view>
</view>
