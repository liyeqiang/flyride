<view class="container">
  <view class="card">
    <view class="card-title">订单号</view>
    <text class="order-id">{{orderId}}</text>
  </view>

  <view class="card">
    <view class="card-title">预约信息</view>
    <view class="price-row">
      <text class="price-label">姓名</text>
      <text class="price-value">{{order.riderName || '—'}}</text>
    </view>
    <view class="price-row">
      <text class="price-label">手机号</text>
      <text class="price-value">{{order.riderPhone || '—'}}</text>
    </view>
  </view>

  <view class="card">
    <view class="card-title">流程状态</view>
    <view class="status-list">
      <view class="status-item">
        <text>保险购买</text>
        <text class="status-tag {{insuranceDone ? 'done' : 'pending'}}">
          {{insuranceDone ? '已完成' : '待完成'}}
        </text>
      </view>
      <view class="status-item">
        <text>体验费支付</text>
        <text class="status-tag {{isPaid ? 'done' : 'pending'}}">
          {{isPaid ? '已支付' : '待支付'}}
        </text>
      </view>
    </view>
    <view class="expire-tip" wx:if="{{insuranceDone && !isPaid && expireText}}">
      请在 {{expireText}} 内完成支付
    </view>
  </view>

  <view class="card" wx:if="{{isPaid}}">
    <view class="success-box">
      <text class="success-icon">✓</text>
      <text class="success-title">预约成功</text>
      <text class="success-desc">请携带身份证件到场体验，向工作人员出示此页面核销</text>
    </view>
  </view>

  <block wx:if="{{insuranceDone && !isPaid}}">
    <view class="card">
      <view class="card-title">体验费</view>
      <view class="fee-display">¥198.00</view>
    </view>
    <button class="btn-primary" bindtap="payExperience" disabled="{{paying || expireText === '已超时'}}">
      {{paying ? '支付中...' : '支付体验费 ¥198'}}
    </button>
  </block>

  <block wx:if="{{!insuranceDone}}">
    <button class="btn-secondary" bindtap="goBackInsurance">返回购买保险</button>
  </block>
</view>
