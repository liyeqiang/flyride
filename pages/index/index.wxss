.hero {
  background: linear-gradient(135deg, #0a0a1a 0%, #1a1a3e 100%);
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  margin-bottom: 24rpx;
  color: #fff;
}

.hero-badge {
  display: inline-block;
  background: rgba(108, 92, 231, 0.3);
  color: #a29bfe;
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
}

.hero-title {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.hero-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}
