<view class="container">
  <view class="card">
    <view class="card-title">工作人员核销</view>
    <view class="card-desc">请游客出示预约成功页面的订单号，输入后点击查询核对身份</view>
  </view>

  <view class="card">
    <view class="form-item">
      <text class="form-label">工作人员口令 *</text>
      <input class="form-input" password value="{{staffCode}}" placeholder="请输入口令" bindinput="onStaffCodeInput" />
    </view>
    <view class="form-item">
      <text class="form-label">订单号 *</text>
      <input class="form-input" value="{{orderId}}" placeholder="请输入游客展示的订单号" bindinput="onOrderIdInput" />
    </view>
    <button class="btn-secondary" bindtap="lookup" disabled="{{loading}}">{{loading ? '查询中...' : '查询订单'}}</button>
  </view>

  <view class="card" wx:if="{{order}}">
    <view class="card-title">游客信息</view>
    <view class="price-row">
      <text class="price-label">姓名</text>
      <text class="price-value">{{order.riderName}}</text>
    </view>
    <view class="price-row">
      <text class="price-label">手机号</text>
      <text class="price-value">{{order.riderPhone}}</text>
    </view>
    <view class="price-row">
      <text class="price-label">身份证号</text>
      <text class="price-value">{{order.riderIdNoMasked}}</text>
    </view>
    <view class="price-row">
      <text class="price-label">订单状态</text>
      <text class="status-tag {{order.status === 'completed' ? 'done' : 'pending'}}">{{order.status}}</text>
    </view>
  </view>

  <button class="btn-primary" wx:if="{{order && order.status === 'exp_paid'}}" bindtap="confirmVerify" disabled="{{verifying}}">
    {{verifying ? '核销中...' : '确认核销'}}
  </button>

  <view class="card" wx:if="{{order && order.status === 'completed'}}">
    <view class="success-box">
      <text class="success-icon">✓</text>
      <text class="success-title">已核销</text>
    </view>
  </view>
</view>
