.success-box {
  text-align: center;
  padding: 32rpx 0;
}

.success-icon {
  display: block;
  width: 96rpx;
  height: 96rpx;
  line-height: 96rpx;
  margin: 0 auto 16rpx;
  background: #00b894;
  color: #fff;
  border-radius: 50%;
  font-size: 48rpx;
}

.success-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
}
