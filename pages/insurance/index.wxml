<!-- pages/insurance/index.wxml -->

<!-- ② 外部浏览器降级等待页：仅当内嵌加载失败时才会出现 -->
<view class="page waiting-page" wx:if="{{waiting && !showWebview}}">
  <view class="step-bar">
    <view class="step done"><view class="step-dot">✓</view><text class="step-label">填信息</text></view>
    <view class="step-line done"></view>
    <view class="step active"><view class="step-dot">2</view><text class="step-label">买保险</text></view>
    <view class="step-line"></view>
    <view class="step"><view class="step-dot">3</view><text class="step-label">付体验费</text></view>
  </view>

  <view class="wait-center">
    <view class="wait-ring"></view>
    <text class="wait-title">请在微信浏览器中完成保险购买</text>
    <text class="wait-sub">支付完成后，点击浏览器左上角返回键回到此页</text>
    <text class="wait-sub">系统将自动检测保险状态...</text>
  </view>

  <view class="section card ins-detail-card" style="margin-top:0">
    <view class="ins-row">
      <text class="ins-key">保险费用</text>
      <text class="ins-val highlight">¥20.00</text>
    </view>
    <view class="ins-row" style="border:none;margin:0;padding:0">
      <text class="ins-key">承保机构</text>
      <text class="ins-val">中国人寿电商平台</text>
    </view>
  </view>

  <button class="btn btn-secondary" style="margin-top:24rpx" bindtap="openInsurance">
    重新打开保险页面
  </button>
  <button class="btn btn-ghost" bindtap="skipInsurance">
    已完成购险，手动继续
  </button>
</view>

<!-- ③ web-view 内嵌保险H5：默认打开方式，直接在小程序内展示 -->
<view class="webview-page" wx:if="{{showWebview}}">
  <web-view src="{{insuranceUrl}}"
            bindmessage="onWebviewMsg"
            bindload="onWebviewLoad"
            binderror="onWebviewError"/>
  <cover-view class="webview-fab" bindtap="showWebviewActions">···</cover-view>
</view>
