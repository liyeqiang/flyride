/* pages/insurance/index.wxss */
.ins-detail-card { padding: 0; overflow: hidden; }
.ins-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 28rpx 36rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.ins-key { font-size: 28rpx; color: #78909c; }
.ins-val { font-size: 28rpx; color: #1a1a2e; font-weight: 500; }
.ins-val.highlight { color: #e53935; font-size: 34rpx; font-weight: 700; }

/* 等待状态 */
.waiting-page { background: #f5f7ff; }
.wait-center {
  display: flex; flex-direction: column; align-items: center;
  padding: 60rpx 48rpx 48rpx;
}
.wait-ring {
  width: 100rpx; height: 100rpx;
  border: 8rpx solid #e3f2fd;
  border-top-color: #1a73e8;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
  margin-bottom: 40rpx;
}
@keyframes spin { to { transform: rotate(360deg); } }
.wait-title {
  font-size: 32rpx; font-weight: 600;
  color: #1a1a2e; text-align: center;
  margin-bottom: 20rpx; line-height: 1.5;
}
.wait-sub {
  font-size: 26rpx; color: #78909c;
  text-align: center; line-height: 1.7;
  margin-bottom: 8rpx;
}

/* web-view 内嵌保险H5：仅用一个悬浮小按钮承载操作入口，避免遮挡/拦截 H5 页面自身的弹窗与按钮 */
.webview-page { position: relative; width: 100%; height: 100vh; }
.webview-fab {
  position: fixed; right: 24rpx; bottom: calc(48rpx + env(safe-area-inset-bottom));
  width: 96rpx; height: 96rpx; line-height: 96rpx; text-align: center;
  border-radius: 50%;
  background: rgba(26, 115, 232, 0.92); color: #fff;
  font-size: 44rpx; font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.25);
}
