/* pages/insurance/index.wxss */
.ins-hero {
  display: flex; flex-direction: column; align-items: center;
  padding: 60rpx 32rpx 40rpx;
}
.ins-icon-big { font-size: 100rpx; }
.ins-title { font-size: 40rpx; font-weight: 700; color: #1a1a2e; margin-top: 20rpx; }
.ins-sub { font-size: 26rpx; color: #78909c; margin-top: 10rpx; }

.ins-detail-card { padding: 0; overflow: hidden; }
.ins-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 28rpx 36rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.ins-key { font-size: 28rpx; color: #78909c; }
.ins-val { font-size: 28rpx; color: #1a1a2e; font-weight: 500; }
.ins-val.highlight { color: #e53935; font-size: 34rpx; font-weight: 700; }

.ins-notice {
  background: #fff8e1; border-radius: 12rpx;
  padding: 24rpx 28rpx; margin-top: 24rpx;
  font-size: 26rpx; color: #795548; line-height: 1.7;
}

/* 等待状态 */
.waiting-page { background: #f5f7ff; }
.wait-center {
  display: flex; flex-direction: column; align-items: center;
  padding: 60rpx 48rpx 48rpx;
}
.wait-ring {
  width: 100rpx; height: 100rpx;
  border: 8rpx solid #e3f2fd;
  border-top-color: #1a73e8;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
  margin-bottom: 40rpx;
}
@keyframes spin { to { transform: rotate(360deg); } }
.wait-title {
  font-size: 32rpx; font-weight: 600;
  color: #1a1a2e; text-align: center;
  margin-bottom: 20rpx; line-height: 1.5;
}
.wait-sub {
  font-size: 26rpx; color: #78909c;
  text-align: center; line-height: 1.7;
  margin-bottom: 8rpx;
}
