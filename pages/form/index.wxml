<view class="container">
  <view class="card">
    <view class="card-title">乘客信息</view>
    <view class="card-desc">以下信息用于购买保险及现场核销</view>
  </view>

  <view class="card">
    <view class="form-item">
      <text class="form-label">姓名 *</text>
      <input class="form-input" placeholder="请输入真实姓名" value="{{riderName}}" data-field="riderName" bindinput="onInput" />
    </view>
    <view class="form-item">
      <text class="form-label">手机号 *</text>
      <input class="form-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{riderPhone}}" data-field="riderPhone" bindinput="onInput" />
    </view>
    <view class="form-item">
      <text class="form-label">身份证号 *</text>
      <input class="form-input" maxlength="18" placeholder="请输入身份证号" value="{{riderIdNo}}" data-field="riderIdNo" bindinput="onInput" />
    </view>
    <view class="form-item">
      <text class="form-label">体重 (kg)</text>
      <input class="form-input" type="digit" placeholder="选填，不超过120" value="{{riderWeight}}" data-field="riderWeight" bindinput="onInput" />
    </view>
  </view>

  <button class="btn-primary" bindtap="submit" disabled="{{submitting}}">
    {{submitting ? '提交中...' : '下一步：购买保险'}}
  </button>
</view>
