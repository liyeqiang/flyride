page {
  background: #f5f7ff;
  color: #1a1a2e;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  box-sizing: border-box;
}

.container {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(10, 10, 26, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  font-size: 28rpx;
}

.price-row + .price-row {
  border-top: 1rpx solid #f0f0f5;
}

.price-label {
  color: #666;
}

.price-value {
  font-weight: 600;
  color: #1a1a2e;
}

.price-total {
  font-size: 36rpx;
  color: #6c5ce7;
}

.btn-primary {
  background: linear-gradient(135deg, #6c5ce7, #a29bfe);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  height: 96rpx;
  line-height: 96rpx;
  border: none;
  margin-top: 32rpx;
}

.btn-primary[disabled] {
  opacity: 0.6;
}

.btn-secondary {
  background: #fff;
  color: #6c5ce7;
  border: 2rpx solid #6c5ce7;
  border-radius: 48rpx;
  font-size: 28rpx;
  height: 88rpx;
  line-height: 88rpx;
  margin-top: 16rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-input {
  background: #f8f9ff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.status-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  background: #eef0ff;
  color: #6c5ce7;
}

.status-tag.done {
  background: #e8f8ef;
  color: #00b894;
}

.status-tag.pending {
  background: #fff3e0;
  color: #e17055;
}
